#include <stdio.h>
int main() {
    int i,n,sum=0;
    printf("enter the number of elements to be inserted:");
    scanf("%d",&n);
    int arr[n];
    printf("enter the elments of the array\n");
    for(i=0;i<n;i++){
        printf("enter element");
        scanf("%d",&arr[i]);
    }
    for(i=0;i<n;i++){
        sum=sum+arr[i];
    }
    printf("sum of the entered elements:%d",sum);
    return 0;
}
