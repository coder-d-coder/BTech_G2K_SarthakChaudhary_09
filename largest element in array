#include <stdio.h>

int main() {
    int arr[100];
    int n;
    printf("enter the number of elements in the array: \n");
    scanf("%d",&n);
    printf("Enter array elements: \n");
    for(int i=0; i<n; i++){
        scanf("%d", &arr[i]);
    }
    int maxx= arr[0];
    for(int i=0; i<n; i++){
        if(maxx<arr[i]){
            maxx=arr[i];
        }
        
    }
    printf("the largest element in the array is %d", maxx);
    return 0;
}
