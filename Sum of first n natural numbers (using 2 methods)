#include <stdio.h>
int main()
{
    int n, sum1 = 0, sum2 = 0, i;
    printf("Enter the number:");
    scanf("%d", &n);
    sum1 = (n * (n + 1)) / 2;
    printf("Method 1:");
    printf("The sum of natural number is:%d\n5", sum1);

    for (i = 1; i <= n; i++)
    {
        sum2 += i;
    }
    printf("Method 2:");
    printf("The sum of natural number is:%d", sum2);
    return 0;
}
